# =============================================================================
# 环境变量模板（仅示例，不含真实密钥）
# 复制本文件为 .env 后在本地填写；切勿把含真实密码的 .env 提交仓库（.gitignore 已忽略 .env）
# =============================================================================

FLASK_ENV=development
# 生产环境请改为足够长的随机串，例如：python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=<请填写随机长字符串>

MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=<请填写本地 MySQL 密码>
MYSQL_DATABASE=iot_platform

# 火山引擎方舟：控制台创建推理接入点；Key 与接入点 ID 勿泄露、勿写入本模板真实值
AI_API_KEY=<请填写或留空以使用本地模板降级>
AI_MODEL=<请填写推理接入点 ID，如 doubao-xxx-xxxxxxxx>
# 一般无需修改；若使用其他地域/代理可改
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# 方舟请求超时与重试（避免部署时 gunicorn worker 超时）
AI_HTTP_TIMEOUT=12
AI_MAX_RETRIES=2

# 温度告警邮件（SMTP）；以下为占位，请用你自己的邮箱与授权码/应用密码
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_USER=<你的发件邮箱，如 name@163.com>
SMTP_PASSWORD=<邮箱 SMTP 授权码或应用专用密码，勿用登录密码>
SMTP_SENDER=<发件人显示地址，通常与 SMTP_USER 相同>
SMTP_SSL=1
TEMP_ALERT_COOLDOWN_MINUTES=10
